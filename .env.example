# --- Anthropic API ---
# Required: your Anthropic API key for answer generation.
ANTHROPIC_API_KEY=

# Model tiering (see docs/ADR.md section 4.1).
# Synthesis: the user-facing, citation-bearing answer.
SYNTH_MODEL=claude-sonnet-4-6
# Decomposition + grading: cheap, high-frequency, structured judgments.
GRADER_MODEL=claude-haiku-4-5

# --- Embeddings (local) ---
# Local sentence-transformers model used for both ingestion and retrieval.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Dimensionality of the embedding model above (bge-small-en-v1.5 -> 384).
EMBEDDING_DIM=384

# --- Corpus / ingestion ---
# Path to the Kaggle arXiv metadata JSON (one JSON object per line).
# https://www.kaggle.com/datasets/Cornell-University/arxiv
CORPUS_PATH=_data/arxiv-metadata-oai-snapshot.json
# arXiv category to scope the index to (keeps the index laptop-friendly).
ARXIV_CATEGORY=cs.LG
# Maximum number of papers to ingest (cap for a laptop-friendly index).
MAX_PAPERS=50000
# Batch size for embedding + upserting during ingestion.
INGEST_BATCH_SIZE=256

# --- Retrieval ---
# Chunks (papers) retrieved per sub-query.
TOP_K=5
# Minimum cosine score for a retrieved chunk to be considered at all.
SCORE_THRESHOLD=0.3

# --- Agent ---
# Maximum number of sub-queries a question is decomposed into.
MAX_SUBQUERIES=3
# Maximum number of corrective re-retrievals per sub-query.
MAX_RETRIES=1
# arXiv API request timeout, in seconds.
ARXIV_TIMEOUT=10.0

# --- Qdrant ---
# Qdrant endpoint. Inside docker-compose this is overridden to http://qdrant:6333.
QDRANT_URL=http://localhost:6333
# Name of the Qdrant collection holding the embedded corpus.
QDRANT_COLLECTION=arxiv_papers
